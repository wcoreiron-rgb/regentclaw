# Copy this to .env and customize for your environment

DATABASE_URL=postgresql+asyncpg://regentclaw:regentclaw@db:5432/regentclaw
DATABASE_URL_SYNC=postgresql://regentclaw:regentclaw@db:5432/regentclaw
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000"]

# AGT rollout flags
AGT_VERSION_MODE=v1_compat
AGT_ENABLE_AGENT_MESH=false
AGT_ENABLE_E2E_MESSAGING=false
AGT_ENABLE_MCP_GATEWAY=false
AGT_ENABLE_SHADOW_DISCOVERY=false
