# RegentClaw — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://regentclaw:regentclaw@localhost:5432/regentclaw
POSTGRES_USER=regentclaw
POSTGRES_PASSWORD=regentclaw
POSTGRES_DB=regentclaw

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=RegentClaw
APP_VERSION=0.1.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000

# Optional: AI providers (for ArcClaw / Copilot NL workflow generation)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
