# RegentClaw — Environment Variables
# Copy this file to .env and fill in your values
#
# ⚠️  SECURITY REQUIREMENTS (must change before any non-local deployment):
#   1. SECRET_KEY  — generate with: python -c "import secrets; print(secrets.token_hex(32))"
#   2. POSTGRES_PASSWORD — change from the default
#   3. REDIS_PASSWORD    — set a strong password
#   4. DEBUG=false       — never enable in production (bypasses all auth)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://regentclaw:CHANGE_ME@localhost:5432/regentclaw
POSTGRES_USER=regentclaw
POSTGRES_PASSWORD=CHANGE_ME        # ← must change
POSTGRES_DB=regentclaw

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME           # ← must change

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=RegentClaw
APP_VERSION=0.1.0
DEBUG=false                        # ← NEVER set true in production
ALLOWED_ORIGINS=http://localhost:3000

# Optional: AI providers (for ArcClaw / Copilot NL workflow generation)
# Add these via Connectors UI — they are encrypted and stored locally.
# You can also set them here as environment variable overrides.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
NVIDIA_API_KEY=           # Free — get at https://build.nvidia.com/models
